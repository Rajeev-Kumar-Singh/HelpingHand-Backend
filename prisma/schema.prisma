generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  VOLUNTEER
}

enum DonationStatus {
  PENDING
  RECEIVED
  FAILED
  REFUNDED
}

enum VolunteerStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum BeneficiaryStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  ON_HOLD
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  passwordHash     String
  fullName         String
  role             UserRole   @default(STAFF)
  phone            String?
  donations        Donation[]
  volunteerProfile Volunteer?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Donation {
  id          String         @id @default(cuid())
  donorName   String
  donorEmail  String?
  amount      Decimal        @db.Decimal(12, 2)
  currency    String         @default("INR")
  status      DonationStatus @default(PENDING)
  donatedAt   DateTime       @default(now())
  message     String?
  createdById String?
  createdBy   User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
  @@index([donatedAt])
}

model Volunteer {
  id           String          @id @default(cuid())
  userId       String          @unique
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       String[]
  availability String?
  status       VolunteerStatus @default(PENDING)
  joinedAt     DateTime        @default(now())
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status])
}

model Beneficiary {
  id            String            @id @default(cuid())
  fullName      String
  contactPhone  String?
  householdSize Int?
  city          String?
  state         String?
  supportNeeded String
  status        BeneficiaryStatus @default(PENDING_REVIEW)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
}
