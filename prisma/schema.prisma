generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  VOLUNTEER
}

enum DonationStatus {
  PENDING
  RECEIVED
  FAILED
  REFUNDED
}

enum VolunteerStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum BeneficiaryStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  ON_HOLD
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

model User {
  id               String     @id @default(cuid())
  email            String     @unique
  passwordHash     String
  fullName         String
  role             UserRole   @default(STAFF)
  phone            String?
  donations        Donation[]
  volunteerProfile Volunteer?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Donation {
  id          String         @id @default(cuid())
  donorName   String
  donorEmail  String?
  amount      Decimal        @db.Decimal(12, 2)
  currency    String         @default("INR")
  status      DonationStatus @default(PENDING)
  donatedAt   DateTime       @default(now())
  message     String?
  createdById String?
  createdBy   User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
  @@index([donatedAt])
}

model Volunteer {
  id           String          @id @default(cuid())
  userId       String          @unique
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       String[]
  availability String?
  status       VolunteerStatus @default(PENDING)
  joinedAt     DateTime        @default(now())
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status])
}

model Beneficiary {
  id            String            @id @default(cuid())
  fullName      String
  contactPhone  String?
  householdSize Int?
  city          String?
  state         String?
  supportNeeded String
  status        BeneficiaryStatus @default(PENDING_REVIEW)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([status])
}

model Program {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  summary        String
  description    String
  category       String?
  coverImageUrl  String?
  targetAmount   Decimal?      @db.Decimal(12, 2)
  raisedAmount   Decimal?      @db.Decimal(12, 2)
  beneficiaryCnt Int?          @default(0)
  status         PublishStatus @default(DRAFT)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([startsAt])
}

model Event {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  description  String
  location     String?
  eventDate    DateTime
  coverImageUrl String?
  registrationUrl String?
  status       PublishStatus @default(DRAFT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([eventDate])
  @@index([status])
}

model SuccessStory {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  excerpt        String
  story          String
  beneficiaryName String?
  coverImageUrl  String?
  status         PublishStatus @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status])
  @@index([publishedAt])
}

model GalleryItem {
  id          String        @id @default(cuid())
  title       String
  imageUrl    String
  category    String?
  caption     String?
  takenAt     DateTime?
  status      PublishStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([takenAt])
}

model ContactInquiry {
  id         String        @id @default(cuid())
  fullName   String
  email      String
  phone      String?
  subject    String?
  message    String
  sourcePage String?
  status     InquiryStatus @default(NEW)
  repliedAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model NewsletterSubscriber {
  id            String   @id @default(cuid())
  email         String   @unique
  fullName      String?
  isActive      Boolean  @default(true)
  subscribedAt  DateTime @default(now())
  unsubscribedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([subscribedAt])
}
